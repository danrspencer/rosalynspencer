---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Rosalyn Spencer — author and writing retreat host."
  section="author"
>

  <div class="max-w-2xl mx-auto px-6 pt-20 pb-24">
    <h1 class="font-serif text-5xl font-semibold text-ink mb-4">Get in Touch</h1>
    <p class="font-sans text-warm-400 text-lg mb-12">I would love to hear from you.</p>

    <!-- Direct contact -->
    <div class="flex flex-col sm:flex-row gap-6 mb-12">
      <a
        href="tel:07979793677"
        class="flex items-center gap-3 bg-parchment-dark rounded-xl px-6 py-4 hover:bg-warm-100 transition-colors group"
      >
        <svg class="w-5 h-5 text-sage shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
        </svg>
        <div>
          <p class="font-sans text-xs text-warm-400 uppercase tracking-wide">Phone</p>
          <p class="font-sans text-sm text-ink group-hover:text-sage transition-colors">07979 793677</p>
        </div>
      </a>
      <a
        href="mailto:rosalyn@spencer-johnson.co.uk"
        class="flex items-center gap-3 bg-parchment-dark rounded-xl px-6 py-4 hover:bg-warm-100 transition-colors group"
      >
        <svg class="w-5 h-5 text-sage shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
        </svg>
        <div>
          <p class="font-sans text-xs text-warm-400 uppercase tracking-wide">Email</p>
          <p class="font-sans text-sm text-ink group-hover:text-sage transition-colors">rosalyn@spencer-johnson.co.uk</p>
        </div>
      </a>
    </div>

    <!-- Form -->
    <div class="bg-parchment-dark rounded-2xl p-8">
      <h2 class="font-serif text-2xl text-ink mb-6">Send a Message</h2>
      <form
        name="contact"
        method="POST"
        netlify
        class="space-y-5"
      >
        <input type="hidden" name="form-name" value="contact" />

        <div>
          <label for="name" class="block font-sans text-sm text-ink-light mb-1.5">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full font-sans text-sm bg-white border border-warm-200 rounded-lg px-4 py-2.5 text-ink placeholder-warm-200 focus:outline-none focus:border-sage transition-colors"
            placeholder="Your name"
          />
        </div>

        <div>
          <label for="email" class="block font-sans text-sm text-ink-light mb-1.5">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full font-sans text-sm bg-white border border-warm-200 rounded-lg px-4 py-2.5 text-ink placeholder-warm-200 focus:outline-none focus:border-sage transition-colors"
            placeholder="your@email.com"
          />
        </div>

        <div>
          <label for="message" class="block font-sans text-sm text-ink-light mb-1.5">Message</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            class="w-full font-sans text-sm bg-white border border-warm-200 rounded-lg px-4 py-2.5 text-ink placeholder-warm-200 focus:outline-none focus:border-sage transition-colors resize-none"
            placeholder="What would you like to say?"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full bg-sage text-white font-sans text-sm font-medium tracking-wide py-3 rounded-full hover:bg-sage-light transition-colors"
        >
          Send Message
        </button>
      </form>
    </div>
  </div>

</BaseLayout>
