---
import { AUTHOR_URL, RETREAT_URL } from '../config';

interface Props {
  section?: 'author' | 'retreat';
}

const { section = 'author' } = Astro.props;
const isRetreat = section === 'retreat';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

// Main nav links for each section (same-site relative links)
const mainLinks = isRetreat
  ? [
      { href: `${RETREAT_URL}`,         label: 'Retreat' },
      { href: `${RETREAT_URL}/contact`, label: 'Contact' },
      { href: `${RETREAT_URL}/links`,   label: 'Links'   },
    ]
  : [
      { href: '/',        label: 'Home'     },
      { href: '/about',   label: 'About'    },
      { href: '/book',    label: 'Book'     },
      { href: '/writing', label: 'Articles' },
      { href: '/contact', label: 'Contact'  },
      { href: '/links',   label: 'Links'    },
    ];

// Cross-section gateway link
const crossLink = isRetreat
  ? { href: `${AUTHOR_URL}/`,   label: '\u2190 Writing' }
  : { href: `${RETREAT_URL}`,   label: 'Retreat \u2192' };

// Accent colours
const activeClass    = isRetreat ? 'text-forest font-medium' : 'text-sage font-medium';
const hoverClass     = isRetreat ? 'text-ink-light hover:text-forest' : 'text-ink-light hover:text-sage';
const crossHover     = isRetreat ? 'text-warm-400 hover:text-forest' : 'text-warm-400 hover:text-sage';

// Wordmark
const wordmarkHref    = isRetreat ? `${RETREAT_URL}` : '/';
const wordmarkPrimary = isRetreat ? "Longthwaite Writers\u2019 Retreat" : 'Rosalyn Spencer';
const wordmarkSub     = isRetreat ? 'Rosalyn Spencer' : 'Author & Writing Retreat Host';
const wordmarkColour  = isRetreat ? 'text-forest' : 'text-ink';
const wordmarkHover   = isRetreat ? 'group-hover:text-forest-dark' : 'group-hover:text-sage';
---

<header class:list={[
  'sticky top-0 z-50 backdrop-blur-sm',
  isRetreat ? 'border-b border-forest/30 bg-parchment/95' : 'border-b border-warm-200 bg-parchment/95',
]}>
  <!-- Retreat accent strip -->
  {isRetreat && <div class="h-0.5 bg-forest" />}

  <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between gap-6">
    <!-- Wordmark -->
    <a href={wordmarkHref} class="flex flex-col leading-tight group shrink-0">
      <span class:list={['font-serif text-2xl font-semibold transition-colors', wordmarkColour, wordmarkHover]}>
        {wordmarkPrimary}
      </span>
      <span class="font-sans text-xs text-warm-400 tracking-wide">
        {wordmarkSub}
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-1">
      {mainLinks.map(({ href, label }) => {
        const isActive = href === '/' || href === RETREAT_URL
          ? currentPath === '/' || currentPath === '/retreat'
          : currentPath.startsWith(href);
        return (
          <a
            href={href}
            class:list={[
              'font-sans text-sm tracking-wide transition-colors px-2 py-1',
              isActive ? activeClass : hoverClass,
            ]}
          >
            {label}
          </a>
        );
      })}

      <!-- Pipe divider -->
      <span class="w-px h-4 bg-warm-200 mx-2" aria-hidden="true" />

      <!-- Cross-section gateway -->
      <a
        href={crossLink.href}
        class:list={['font-serif italic text-sm transition-colors px-2 py-1', crossHover]}
      >
        {crossLink.label}
      </a>
    </nav>

    <!-- Mobile menu toggle -->
    <button
      id="menu-toggle"
      class:list={['md:hidden p-2 transition-colors', isRetreat ? 'text-ink-light hover:text-forest' : 'text-ink-light hover:text-sage']}
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg id="icon-open" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile nav -->
  <nav id="mobile-menu" class:list={[
    'hidden md:hidden border-t bg-parchment',
    isRetreat ? 'border-forest/30' : 'border-warm-200',
  ]}>
    <div class="max-w-5xl mx-auto px-6 py-4 flex flex-col gap-1">
      {mainLinks.map(({ href, label }) => {
        const isActive = href === '/' || href === RETREAT_URL
          ? currentPath === '/' || currentPath === '/retreat'
          : currentPath.startsWith(href);
        return (
          <a
            href={href}
            class:list={[
              'font-sans text-sm tracking-wide transition-colors py-1',
              isActive ? activeClass : hoverClass,
            ]}
          >
            {label}
          </a>
        );
      })}
      <hr class:list={['my-1', isRetreat ? 'border-forest/20' : 'border-warm-200']} />
      <a
        href={crossLink.href}
        class:list={['font-serif italic text-sm transition-colors py-1', crossHover]}
      >
        {crossLink.label}
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle')!;
  const menu   = document.getElementById('mobile-menu')!;
  const iconOpen  = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  toggle.addEventListener('click', () => {
    const open = menu.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!open));
    iconOpen.classList.toggle('hidden');
    iconClose.classList.toggle('hidden');
  });
</script>
