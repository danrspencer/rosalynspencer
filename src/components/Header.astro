---
interface Props {
  section?: 'author' | 'retreat';
}

const { section = 'author' } = Astro.props;
const isRetreat = section === 'retreat';

const navLinks = [
  { href: '/',        label: 'Home',     side: 'author'  },
  { href: '/about',   label: 'About',    side: 'author'  },
  { href: '/book',    label: 'Book',     side: 'author'  },
  { href: '/writing', label: 'Articles', side: 'author'  },
  { href: '/retreat', label: 'Retreat',  side: 'retreat' },
  { href: '/contact', label: 'Contact',  side: 'shared'  },
  { href: '/links',   label: 'Links',    side: 'shared'  },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

// Accent colours: retreat uses forest green, author uses sage
const activeClass   = isRetreat ? 'text-forest font-medium' : 'text-sage font-medium';
const hoverClass    = isRetreat ? 'text-ink-light hover:text-forest' : 'text-ink-light hover:text-sage';
const wordmarkHover = isRetreat ? 'group-hover:text-forest' : 'group-hover:text-sage';

// Wordmark: on retreat pages flip primary/secondary
const wordmarkHref    = isRetreat ? '/retreat' : '/';
const wordmarkPrimary = isRetreat ? "Longthwaite Writers\u2019 Retreat" : 'Rosalyn Spencer';
const wordmarkSub     = isRetreat ? 'Rosalyn Spencer' : 'Author & Writing Retreat Host';
---

<header class="sticky top-0 z-50 bg-parchment/95 backdrop-blur-sm border-b border-warm-200">
  <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between gap-6">
    <!-- Wordmark -->
    <a href={wordmarkHref} class="flex flex-col leading-tight group">
      <span class:list={['font-serif text-2xl font-semibold text-ink transition-colors', wordmarkHover]}>
        {wordmarkPrimary}
      </span>
      <span class="font-sans text-xs text-warm-400 tracking-wide">
        {wordmarkSub}
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-1">
      {navLinks.map(({ href, label, side }, i) => {
        const isActive = href === '/'
          ? currentPath === '/'
          : currentPath.startsWith(href);

        // Visual divider before 'Retreat'
        const showDivider = side === 'retreat' && navLinks[i - 1]?.side === 'author';

        return (
          <>
            {showDivider && (
              <span class="w-px h-4 bg-warm-200 mx-2" aria-hidden="true" />
            )}
            <a
              href={href}
              class:list={[
                'font-sans text-sm tracking-wide transition-colors px-2 py-1',
                isActive ? activeClass : hoverClass
              ]}
            >
              {label}
            </a>
          </>
        );
      })}
    </nav>

    <!-- Mobile menu toggle -->
    <button
      id="menu-toggle"
      class:list={['md:hidden p-2 transition-colors', isRetreat ? 'text-ink-light hover:text-forest' : 'text-ink-light hover:text-sage']}
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg id="icon-open" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile nav -->
  <nav id="mobile-menu" class="hidden md:hidden border-t border-warm-200 bg-parchment">
    <div class="max-w-5xl mx-auto px-6 py-4 flex flex-col gap-1">
      {navLinks.map(({ href, label, side }, i) => {
        const isActive = href === '/'
          ? currentPath === '/'
          : currentPath.startsWith(href);
        const showDivider = side === 'retreat' && navLinks[i - 1]?.side === 'author';
        return (
          <>
            {showDivider && <hr class="border-warm-200 my-1" />}
            <a
              href={href}
              class:list={[
                'font-sans text-sm tracking-wide transition-colors py-1',
                isActive ? activeClass : hoverClass
              ]}
            >
              {label}
            </a>
          </>
        );
      })}
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle')!;
  const menu   = document.getElementById('mobile-menu')!;
  const iconOpen  = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  toggle.addEventListener('click', () => {
    const open = menu.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!open));
    iconOpen.classList.toggle('hidden');
    iconClose.classList.toggle('hidden');
  });
</script>
