---
interface Props {
  quote: string;
  attribution?: string;
  variant?: 'amber' | 'sage' | 'plain';
}

const { quote, attribution, variant = 'amber' } = Astro.props;

const variantClasses = {
  amber: 'bg-amber-pale border-amber',
  sage:  'bg-sage-pale  border-sage',
  plain: 'bg-warm-100   border-warm-200',
};
---

<blockquote class:list={['border-l-4 px-6 py-5 rounded-r-lg', variantClasses[variant]]}>
  <p class="font-serif italic text-xl leading-relaxed text-ink-light">&ldquo;{quote}&rdquo;</p>
  {attribution && (
    <footer class="mt-3 font-sans text-sm text-warm-400 not-italic">&mdash; {attribution}</footer>
  )}
</blockquote>
