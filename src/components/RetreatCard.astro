---
interface Props {
  dates: string;
  title: string;
  price: string;
  duration: string;
  href: string;
}

const { dates, title, price, duration, href } = Astro.props;
---

<a
  href={href}
  class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 py-4 border-b border-warm-200 last:border-0 group hover:bg-forest-pale/40 -mx-6 px-6 transition-colors first:rounded-t-xl last:rounded-b-xl"
>
  <div class="flex flex-col gap-0.5">
    <span class="font-sans text-sm text-warm-400">{dates}</span>
    <span class="font-serif text-lg text-ink group-hover:text-forest transition-colors">{title}</span>
  </div>
  <div class="flex items-center gap-3 shrink-0">
    <span class="font-sans text-xs text-warm-400">{duration}</span>
    <span class="font-sans text-sm font-medium text-amber bg-amber-pale px-3 py-1 rounded-full whitespace-nowrap">
      {price}
    </span>
    <span class="font-sans text-xs text-forest opacity-0 group-hover:opacity-100 transition-opacity">Enquire&nbsp;&rarr;</span>
  </div>
</a>
