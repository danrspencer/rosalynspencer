---
import { imageSize } from 'image-size';
import { readFileSync } from 'fs';
import { join } from 'path';

interface GalleryImage {
  src: string;   // e.g. '/images/gallery/01.jpg'
  alt: string;
}

interface Props {
  images: GalleryImage[];
}

const { images } = Astro.props;

// Read actual pixel dimensions at build time for PhotoSwipe + justified layout
const imagesWithDimensions = images.map(({ src, alt }) => {
  const filepath = join(process.cwd(), 'public', src.replace(/^\//, ''));
  const buf = readFileSync(filepath);
  const { width, height } = imageSize(buf);
  return { src, alt, width: width!, height: height! };
});
---

<!--
  Justified row layout (Flickr/Google Photos style):
  Each row is the same height, widths vary to fill the container.
  JavaScript computes the layout client-side using the real image dimensions.
-->
<div id="gallery" class="relative w-full">
  {imagesWithDimensions.map(({ src, alt, width, height }) => (
    <a
      href={src}
      data-pswp-width={width}
      data-pswp-height={height}
      data-w={width}
      data-h={height}
      class="absolute overflow-hidden rounded-lg group cursor-zoom-in"
    >
      <img
        src={src}
        alt={alt}
        loading="lazy"
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      />
    </a>
  ))}
</div>

<style is:global>
  @import 'photoswipe/dist/photoswipe.css';
</style>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  // @ts-ignore — justified-layout is a CJS module, no types package needed
  import justifiedLayout from 'justified-layout';

  const container = document.getElementById('gallery')!;

  function layoutGallery() {
    const items = Array.from(container.querySelectorAll<HTMLElement>('a[data-w]'));
    const dims = items.map(el => ({
      width: parseInt(el.dataset.w!),
      height: parseInt(el.dataset.h!),
    }));

    const containerWidth = container.offsetWidth;
    const geometry = justifiedLayout(dims, {
      containerWidth,
      targetRowHeight: 230,
      targetRowHeightTolerance: 0.2,
      boxSpacing: { horizontal: 8, vertical: 8 },
      containerPadding: 0,
    });

    container.style.height = geometry.containerHeight + 'px';

    items.forEach((el, i) => {
      const box = geometry.boxes[i];
      el.style.left   = box.left + 'px';
      el.style.top    = box.top + 'px';
      el.style.width  = box.width + 'px';
      el.style.height = box.height + 'px';
    });
  }

  layoutGallery();

  // Re-layout on resize (debounced)
  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(layoutGallery, 150);
  });

  // PhotoSwipe lightbox — no target="_blank" needed, PhotoSwipe intercepts clicks
  const lightbox = new PhotoSwipeLightbox({
    gallery: '#gallery',
    children: 'a[data-pswp-width]',
    pswpModule: () => import('photoswipe'),
    bgOpacity: 0.93,
    padding: { top: 20, bottom: 20, left: 20, right: 20 },
  });

  lightbox.init();
</script>
